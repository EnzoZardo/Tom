{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },

  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],

  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],

  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],

  "autoCloseBefore": ";:.,=}])>\n\t ",

  "folding": {
    "markers": {
      "start": "^\\s*//\\s*#?region\\b",
      "end": "^\\s*//\\s*#?endregion\\b"
    }
  },

  "indentationRules": {
    "increaseIndentPattern": "^.*(\\{[^}\"']*|\\([^\\)\"']*|\\[[^\\]\"']*)$",
    "decreaseIndentPattern": "^\\s*[\\}\\]\\)]"
  }
}