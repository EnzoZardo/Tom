{
  "scopeName": "source.tom",
  "name": "Tom",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#declarations" },
    { "include": "#functions" },
    { "include": "#function-call" },
    { "include": "#types" },
    { "include": "#properties" },
    { "include": "#dot-access" },
    { "include": "#operators" }
  ],

  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.hashtag.tom",
          "match": "#.*$"
        },
        {
          "name": "comment.block.tom",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tom",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.tom",
              "match": "\\\\."
            }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.tom",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tom",
          "match": "\\b(se|para|cada|em|enquanto|senao)\\b"
        },
        {
          "name": "keyword.declaration.tom",
          "match": "\\b(tipo|var|fun|con)\\b"
        }
      ]
    },

    "declarations": {
      "patterns": [
        {
          "name": "meta.variable.declaration.tom",
          "match": "\\b(var|con)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.tom" },
            "2": { "name": "variable.other.tom" }
          }
        },
        {
          "name": "meta.type.declaration.tom",
          "match": "\\b(tipo)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.tom" },
            "2": { "name": "entity.name.type.tom" }
          }
        }
      ]
    },

    "functions": {
      "patterns": [
        {
          "name": "meta.function.definition.tom",
          "match": "\\b(fun)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.tom" },
            "2": { "name": "entity.name.function.tom" }
          }
        },
        {
          "name": "variable.parameter.tom",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=:\\s*[a-zA-Z_\\[] )"
        }
      ]
    },

    "function-call": {
      "patterns": [
        {
          "name": "meta.function.call.tom",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.tom" }
          }
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.tom",
          "match": "\\b(texto|inteiro|nulo|logico|real|caractere)\\b"
        },
        {
          "name": "storage.type.custom.tom",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "meta.type.annotation.tom",
          "match": "(:)\\s*([a-zA-Z_\\[\\]]+)",
          "captures": {
            "1": { "name": "punctuation.separator.type.tom" },
            "2": { "name": "storage.type.tom" }
          }
        },
        {
          "name": "storage.type.array.tom",
          "match": "\\[\\]\\s*[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },

    "properties": {
      "patterns": [
        {
          "name": "variable.other.property.tom",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=:)",
          "captures": {
            "1": { "name": "variable.other.property.tom" }
          }
        }
      ]
    },

    "dot-access": {
      "patterns": [
        {
          "name": "meta.member.access.tom",
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)(\\.)",
          "captures": {
            "1": { "name": "variable.other.object.tom" },
            "2": { "name": "punctuation.accessor.dot.tom" }
          }
        },
        {
          "name": "variable.other.property.tom",
          "match": "(?<=\\.)[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.tom",
          "match": "==|=|\\+|-|\\*|/|:|<>"
        }
      ]
    }
  }
}