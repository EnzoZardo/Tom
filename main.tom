var informado: inteiro = inteiro.converte(leia("Informe qualquer número:"))

se (informado) 
{
    escreva("O usuário te informou um texto vazio, que sacanagem...")
} 
senao
{
    escreva("Opa, o conteudo era:", informado, "\nMas vamos soletrar:")
    
    para cada (digito em informado) 
    {
        escreva(digito)
    }
}